# ============================================================
# Nginx Reverse Proxy — AIDAHO University Service
# ============================================================
#
# Routes:
#   yourdomain.com                    -> Landing page
#   ${ORG1_SUBDOMAIN}.yourdomain.com  -> AIDAHO Copilot (Open WebUI)
#   ${N8N_ORG1_SUBDOMAIN}.yourdomain.com -> AIDAHO Workflow (n8n)
#
# For local testing with DOMAIN=localhost:
#   localhost                         -> Landing page
#   ${ORG1_SUBDOMAIN}.localhost       -> AIDAHO Copilot (Open WebUI)
#   ${N8N_ORG1_SUBDOMAIN}.localhost   -> AIDAHO Workflow (n8n)
# ============================================================

# Longer org-specific hostnames require a larger server-name hash.
server_names_hash_bucket_size 128;
server_names_hash_max_size 1024;

# WebSocket upgrade map (required for Open WebUI real-time features)
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

map $http_x_forwarded_proto $forwarded_proto {
    default $http_x_forwarded_proto;
    ''      $scheme;
}

# Rate limiting tuned for SPA asset bursts during page load.
limit_req_zone $binary_remote_addr zone=general:10m rate=100r/s;

# --------------------------------------------------------------
# Landing Page
# --------------------------------------------------------------
server {
    listen 80;
    server_name ${DOMAIN} localhost;

    root /usr/share/nginx/html;
    index index.html;

    limit_req zone=general burst=400;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/admin/ {
        proxy_pass         http://admin-monitor:3000/api/admin/;
        proxy_http_version 1.1;

        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $forwarded_proto;

        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
    }

    location /health/admin-monitor {
        proxy_pass         http://admin-monitor:3000/health;
        proxy_http_version 1.1;

        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $forwarded_proto;
    }
}

# --------------------------------------------------------------
# AIDAHO Copilot — Reverse Proxy to Open WebUI
# --------------------------------------------------------------
server {
    listen 80;
    server_name ${ORG1_SUBDOMAIN}.${DOMAIN} ${ORG1_SUBDOMAIN}.localhost;

    client_max_body_size 100M;   # Allow large file uploads for RAG
    limit_req zone=general burst=400;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        proxy_pass         http://openwebui-aidaho:8080;
        proxy_http_version 1.1;

        # WebSocket support
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection $connection_upgrade;

        # Forward client info
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $forwarded_proto;

        # Disable buffering for streaming LLM responses
        proxy_buffering    off;
        proxy_cache        off;

        # Long timeouts for LLM inference
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}

# --------------------------------------------------------------
# AIDAHO Workflow — Reverse Proxy to n8n
# --------------------------------------------------------------
server {
    listen 80;
    server_name ${N8N_ORG1_SUBDOMAIN}.${DOMAIN} ${N8N_ORG1_SUBDOMAIN}.localhost;

    client_max_body_size 25M;
    limit_req zone=general burst=400;

    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        proxy_pass         http://n8n-aidaho:5678;
        proxy_http_version 1.1;

        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection $connection_upgrade;

        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Host $host;
        proxy_set_header   X-Forwarded-Proto $forwarded_proto;
        proxy_set_header   Origin $forwarded_proto://$host;

        # Disable buffering for n8n editor live updates/reconnects
        proxy_buffering    off;
        proxy_cache        off;

        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
