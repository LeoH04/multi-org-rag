# ============================================================
# Multi-Org Open WebUI — Shared Environment Variables
# ============================================================

# Domain — set to your server's domain name
# For local testing: use "localhost" (access via localhost/org1.localhost/org2.localhost)
# For production:    use your domain (access via org1.yourdomain.com, org2.yourdomain.com)
DOMAIN=localhost

# Department/organization subdomains
ORG1_SUBDOMAIN=gwf-stuttgart
ORG2_SUBDOMAIN=inge-graessle-mdb
ORG3_SUBDOMAIN=albert-schweitzer-kinderdorf

# n8n subdomains (one instance per organization)
N8N_ORG1_SUBDOMAIN=gwf-stuttgart-automations
N8N_ORG2_SUBDOMAIN=inge-graessle-mdb-automations
N8N_ORG3_SUBDOMAIN=albert-schweitzer-kinderdorf-automations

# vLLM chat + reranker (fully self-hosted)
# vLLM downloads models from Hugging Face on first startup and caches them.
VLLM_MODEL=openai/gpt-oss-20b
VLLM_MODEL_NAME=gpt-oss-20b
VLLM_API_KEY=change-me-vllm-key

# Reranker served on /v1/rerank via vLLM
VLLM_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_KEY=change-me-rerank-key

# Hugging Face token is required for gated/private model download.
HF_TOKEN=

# Local embedding model for RAG ingestion/search (sentence-transformers engine)
RAG_EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=aidaho

# Super Admin (same credentials on all Open WebUI instances)
WEBUI_ADMIN_EMAIL=leonard.hegemann@gmx.de
WEBUI_ADMIN_PASSWORD=Leonard2004

# n8n admin access (shared admin login across all org n8n instances)
# Change these credentials before exposing outside localhost.
N8N_ADMIN_USER=admin
N8N_ADMIN_PASSWORD=change-me-now

# n8n encryption key per org (must be unique, 32+ chars)
N8N_ENCRYPTION_KEY_ORG1=replace-with-unique-32-char-min-key-org1
N8N_ENCRYPTION_KEY_ORG2=replace-with-unique-32-char-min-key-org2
N8N_ENCRYPTION_KEY_ORG3=replace-with-unique-32-char-min-key-org3

# Per-instance secret keys (MUST be unique per org)
SECRET_KEY_GWF_STUTTGART=c546e1c4ab17da1222ec0b7c05212d60f8ec788b71f9cf3fbd59cef70bef0314
SECRET_KEY_INGE_GRAESSLE_MDB=8aad7a6d04f3603dec88437185fcb8ea6bb65acc6a4030c2c7b01155206c2f05
SECRET_KEY_ALBERT_SCHWEITZER_KINDERDORF=522993873aefa3c07595f977d81ae35dfd5faac04710e69fb325c5e79c700d6e

# Server GPU
# Assign dedicated GPU/MIG per service if desired.
VLLM_CHAT_VISIBLE_DEVICES=MIG-6846a8ab-ffe4-522b-8d46-0b26a9497114
VLLM_RERANK_VISIBLE_DEVICES=MIG-6846a8ab-ffe4-522b-8d46-0b26a9497114

# Legacy/shared variables kept for compatibility with other services.
NVIDIA_VISIBLE_DEVICES=MIG-6846a8ab-ffe4-522b-8d46-0b26a9497114
CUDA_VISIBLE_DEVICES=MIG-6846a8ab-ffe4-522b-8d46-0b26a9497114