# ============================================================
# Nginx Reverse Proxy — Multi-Org Open WebUI (Production)
# ============================================================
#
# Routes:
#   yourdomain.com        → Landing page
#   ${ORG1_SUBDOMAIN}.yourdomain.com   → Open WebUI GWF Wohnungsgenossenschaft eG
#   ${ORG2_SUBDOMAIN}.yourdomain.com   → Open WebUI Inge Graessle MdB Buero
#   ${ORG3_SUBDOMAIN}.yourdomain.com   → Open WebUI Albert-Schweitzer-Kinderdorf
#   ${N8N_ORG1_SUBDOMAIN}.yourdomain.com → n8n GWF Wohnungsgenossenschaft eG
#   ${N8N_ORG2_SUBDOMAIN}.yourdomain.com → n8n Inge Graessle MdB Buero
#   ${N8N_ORG3_SUBDOMAIN}.yourdomain.com → n8n Albert-Schweitzer-Kinderdorf
#
# HTTPS setup:
#   1. Run: ./generate-certs.sh yourdomain.com   (self-signed, for testing)
#      OR use Let's Encrypt for production:
#      certbot certonly --standalone -d yourdomain.com \
#        -d org1.yourdomain.com -d org2.yourdomain.com
#   2. Place certs in ./certs/fullchain.pem and ./certs/privkey.pem
#   3. Uncomment the HTTPS section below + ports/volumes in docker-compose.yml
#   4. docker compose restart nginx
#
# For local testing with DOMAIN=localhost:
#   localhost              → Landing page
#   ${ORG1_SUBDOMAIN}.localhost         → Open WebUI GWF Wohnungsgenossenschaft eG
#   ${ORG2_SUBDOMAIN}.localhost         → Open WebUI Inge Graessle MdB Buero
#   ${ORG3_SUBDOMAIN}.localhost         → Open WebUI Albert-Schweitzer-Kinderdorf
#   ${N8N_ORG1_SUBDOMAIN}.localhost      → n8n GWF Wohnungsgenossenschaft eG
#   ${N8N_ORG2_SUBDOMAIN}.localhost      → n8n Inge Graessle MdB Buero
#   ${N8N_ORG3_SUBDOMAIN}.localhost      → n8n Albert-Schweitzer-Kinderdorf
# ============================================================

# Longer org-specific hostnames require a larger server-name hash.
server_names_hash_bucket_size 128;
server_names_hash_max_size 1024;

# WebSocket upgrade map (required for Open WebUI real-time features)
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

# Rate limiting tuned for SPA asset bursts during page load.
limit_req_zone $binary_remote_addr zone=general:10m rate=100r/s;

# ──────────────────────────────────────────────
# Landing Page
# ──────────────────────────────────────────────
server {
    listen 80;
    server_name ${DOMAIN};

    root /usr/share/nginx/html;
    index index.html;

    limit_req zone=general burst=400;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}

# ──────────────────────────────────────────────
# GWF Wohnungsgenossenschaft eG — Reverse Proxy to Open WebUI
# ──────────────────────────────────────────────
server {
    listen 80;
    server_name ${ORG1_SUBDOMAIN}.${DOMAIN};

    client_max_body_size 100M;   # Allow large file uploads for RAG
    limit_req zone=general burst=400;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        proxy_pass         http://openwebui-gwf:8080;
        proxy_http_version 1.1;

        # WebSocket support
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection $connection_upgrade;

        # Forward client info
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Disable buffering for streaming LLM responses
        proxy_buffering    off;
        proxy_cache        off;

        # Long timeouts for LLM inference
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}

